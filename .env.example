# Slack bot user OAuth token (xoxb-...). The bot must be invited to the target channel.
SLACK_BOT_TOKEN=xoxb-your-token-here

# Target channel (the channel ID, not the name). Default: #payments-monitoring
SLACK_CHANNEL_ID=C0AVBTM4BG8

# BigQuery project used by the `bq` CLI. The SQL references `maelys-data.spreedly.transactions_s`,
# but `bq` needs a billing/compute project — usually the same.
BQ_PROJECT=maelys-data
